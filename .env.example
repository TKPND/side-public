# Binance Testnet API keys (from testnet.binance.vision, NOT binance.com)
# Generate keys at: https://testnet.binance.vision/
# WARNING: Never commit your real .env file — add .env to .gitignore
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET=your_testnet_secret_here

# FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Google Cloud credentials for GDELT BigQuery (Phase 2)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
